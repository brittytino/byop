# App
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_a_long_random_secret

# GitHub OAuth
# Required on Vercel for Production/Preview/Development environments
GITHUB_ID=replace_with_github_oauth_client_id
GITHUB_SECRET=replace_with_github_oauth_client_secret

# Neon
DATABASE_URL=postgresql://username:password@ep-xxxx.neon.tech/devfoliox?sslmode=require

# SMTP (portfolio contact form)
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM=BYOP <no-reply@your-domain.com>
